# Supabase — copy to .env.local and fill in from your Supabase project settings.
# Project Settings -> API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Optional: the site URL used for magic-link redirects (defaults to the request origin).
# Also used by the MCP server to build deep links back to a created recipe.
# NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Recipe-import MCP server (src/app/api/[transport]) ----------------------
# These power the MCP endpoint at /api/mcp that lets an agent add recipes.
# All are server-only secrets — never expose them to the browser.
#
# Service-role key from Supabase (Project Settings -> API). BYPASSES RLS, so it
# only lives here and is guarded by MCP_AUTH_TOKEN below.
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# The household the MCP server writes into (single-household app). Copy the id
# from the `households` row in Supabase.
# HOUSEHOLD_ID=your-household-uuid
# Shared bearer token for Claude Code (which can send a custom Authorization
# header). Generate a long random value, e.g.  openssl rand -hex 32
# MCP_AUTH_TOKEN=your-long-random-secret
#
# --- OAuth (for claude.ai custom connectors: web / mobile / desktop) ---------
# claude.ai connectors authenticate via OAuth, not a static header, so the app
# runs a tiny OAuth server (src/app/api/oauth/*). Needs migration 0008.
# Secret used to sign OAuth access/refresh tokens (>= 16 chars):
#   openssl rand -hex 32
# OAUTH_JWT_SECRET=your-long-random-secret
# Password a household member types on the connector approval screen to allow
# access. Pick something memorable-but-private.
# MCP_OAUTH_PASSWORD=your-household-password
